# ──────────────────────────────────────────────────────────────────────────
#  Eternal Chess — environment configuration
#  Copy this file to `.env.local` and fill in your own values.
#  NEVER commit `.env.local`. NEVER paste your real key anywhere public.
# ──────────────────────────────────────────────────────────────────────────

# Tatum API key (server-side only — used by /app/api/rpc to sign RPC calls).
# Get a fresh one at https://dashboard.tatum.io/  — if a key ever leaks, rotate it.
TATUM_API_KEY=t-6a1f673f93ee252f9f3601a6-83374d8249274e08809633d7

# Tatum Sui RPC gateway. Switch the subdomain for other networks:
#   mainnet  -> https://sui-mainnet.gateway.tatum.io
#   testnet  -> https://sui-testnet.gateway.tatum.io
#   devnet   -> https://sui-devnet.gateway.tatum.io
TATUM_SUI_RPC=https://sui-mainnet.gateway.tatum.io

# Which Sui network the frontend should assume ("mainnet" | "testnet" | "devnet").
NEXT_PUBLIC_SUI_NETWORK=mainnet

# Your published Move package id (fill in after `sui client publish`).
NEXT_PUBLIC_PACKAGE_ID=0xYOUR_PACKAGE_ID

# ── Walrus ────────────────────────────────────────────────────────────────
# Walrus PUBLISHER handles writes (costs SUI + WAL on mainnet).
#   • Mainnet: there is no free public publisher — run your own (see README)
#     or point this at a hosted/funded publisher you control.
#   • Testnet: public publisher works for free, e.g.
#     https://publisher.walrus-testnet.walrus.space
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space

# Walrus AGGREGATOR serves reads (free, browser-friendly).
#   • Mainnet: https://aggregator.walrus-mainnet.walrus.space
#   • Testnet: https://aggregator.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# How many Walrus storage epochs to keep each blob (1 epoch ≈ 2 weeks).
# Use a large number for "eternal". Higher = more WAL spent up front.
WALRUS_EPOCHS=53
